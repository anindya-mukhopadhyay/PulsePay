NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/pulsepay
CORS_ORIGIN=*
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@pulsepay.local
ADMIN_PASSWORD=change-me

# MetaMask Embedded Wallets / Web3Auth client side configuration reference.
# The backend stores and verifies wallet metadata; private keys remain client/MPC owned.
METAMASK_EMBEDDED_WALLET_CLIENT_ID=
METAMASK_EMBEDDED_WALLET_PROJECT_ID=
METAMASK_WALLET_VERIFY_DOMAIN=PulsePay
WALLET_CHALLENGE_TTL_SECONDS=300

# Blockchain settlement mode: erc4337, superfluid, or offchain
BLOCKCHAIN_FLOW=erc4337
CHAIN_ID=84532
CHAIN_NAME=Base Sepolia
RPC_URL=https://sepolia.base.org
BLOCKSCOUT_API_BASE=https://base-sepolia.blockscout.com/api/v2
EXPLORER_TX_BASE_URL=https://base-sepolia.blockscout.com/tx
LIVE_BALANCE_TIMEOUT_MS=8000

# Real payment asset. For testnet demos, use native ETH/MATIC or a test ERC-20.
# INR_PER_PAYMENT_TOKEN converts app INR billing into token units.
PAYMENT_ASSET_TYPE=native
PAYMENT_TOKEN_ADDRESS=
PAYMENT_TOKEN_SYMBOL=ETH
PAYMENT_TOKEN_DECIMALS=18
INR_PER_PAYMENT_TOKEN=1
PAYMENT_CONFIRMATIONS=1
REQUIRE_ONCHAIN_SETTLEMENT=false

ENTRY_POINT_ADDRESS=0x0000000000000000000000000000000000000000
BUNDLER_URL=
PAYMASTER_URL=
SUPERFLUID_HOST_ADDRESS=
SUPER_TOKEN_ADDRESS=
SERVICE_REGISTRY_ADDRESS=
SESSION_MANAGER_ADDRESS=
