NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/pulsepay
CORS_ORIGIN=*
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@pulsepay.local
ADMIN_PASSWORD=change-me

# MetaMask Embedded Wallets / Web3Auth client side configuration reference.
# The backend stores and verifies wallet metadata; private keys remain client/MPC owned.
METAMASK_EMBEDDED_WALLET_CLIENT_ID=
METAMASK_EMBEDDED_WALLET_PROJECT_ID=

# Blockchain settlement mode: erc4337, superfluid, or offchain
BLOCKCHAIN_FLOW=erc4337
CHAIN_ID=84532
CHAIN_NAME=Base Sepolia
RPC_URL=https://sepolia.base.org
ENTRY_POINT_ADDRESS=0x0000000000000000000000000000000000000000
BUNDLER_URL=
PAYMASTER_URL=
SUPERFLUID_HOST_ADDRESS=
SUPER_TOKEN_ADDRESS=
SERVICE_REGISTRY_ADDRESS=
SESSION_MANAGER_ADDRESS=
